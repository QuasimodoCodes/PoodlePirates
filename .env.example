# Tripletex API credentials
TRIPLETEX_CONSUMER_TOKEN=your-consumer-token-here
TRIPLETEX_EMPLOYEE_TOKEN=your-employee-token-here
TRIPLETEX_COMPANY_ID=0        # 0 = uses the token's company; set to specific ID if multi-company
TRIPLETEX_BASE_URL=https://tripletex.no/v2

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Email ingestion (IMAP)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FOLDER=INBOX

# Agent behaviour
INBOX_FOLDER=./inbox          # local folder to watch for PDF/image drops
LOG_FOLDER=./logs
DRY_RUN=false                 # set true to skip actual Tripletex posting
